rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User-owned data ──────────────────────────────────────────────────
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Premium code claiming ────────────────────────────────────────────
    match /usedCodes/{code} {
      allow get:    if true;
      allow create: if request.resource.data.keys().hasAll(['deviceId', 'usedAt'])
                    && request.resource.data.deviceId is string
                    && request.resource.data.deviceId.size() > 0;
      allow update, delete: if false;
      allow list:   if false;
    }

    // ── Comments ─────────────────────────────────────────────────────────
    // Public can read approved comments; anyone can submit (approved=false enforced);
    // only authenticated users (admin) can approve / delete.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['author', 'text', 'approved', 'createdAt'])
                    && request.resource.data.approved == false
                    && request.resource.data.author is string
                    && request.resource.data.author.size() >= 2
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 8;
      allow update, delete: if request.auth != null;
    }

    // ── Profiles (Leaderboard) ───────────────────────────────────────────
    match /profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /stats/{statId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Match predictions ────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if true;
      // Only authenticated users (admin) can create/delete matches
      allow create, delete: if request.auth != null;
      // Anyone can cast a vote (update only the votes sub-field)
      allow update: if true;
    }

    // ── Community Meta Vote ──────────────────────────────────────────────
    // One document per week (e.g. "2026-W24"), tally map stores vote counts.
    // Read is public; write is open to allow anonymous voting (client enforces
    // one-vote-per-week via localStorage, consistent with /matches pattern).
    match /metaVotes/{weekId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['tally', 'weekKey'])
                    && request.resource.data.tally is map;
      allow update: if true;
    }

    // ── Email subscriptions (CommunityHub) ──────────────────────────────
    match /emails/{emailId} {
      allow create: if request.resource.data.keys().hasAll(['email'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 4;
      allow read, update, delete: if request.auth != null;
    }

  }
}
